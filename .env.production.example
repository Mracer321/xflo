# =============================================================================
# XFlow — PRODUCTION environment template
# Copy to `.env` on the production server and fill in real values.
# After editing: php artisan config:cache && php artisan route:cache && php artisan view:cache
# =============================================================================

APP_NAME=XFlow
APP_ENV=production
APP_KEY=                       # generate once with: php artisan key:generate
APP_DEBUG=false                # MUST be false in production (never leak stack traces)
APP_TIMEZONE=Asia/Kolkata
APP_URL=https://your-domain.com   # real public URL (used by queued notification links)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# --- Logging: daily rotated files, errors only -------------------------------
LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Database (MySQL) --------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=xflow
DB_USERNAME=xflow_app          # use a least-privilege app user, not root
DB_PASSWORD=                   # set a strong password

# --- Sessions ----------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true     # cookies only over HTTPS

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Queues (database driver; run a worker — see docs/DEPLOYMENT.md) ----------
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=90

# --- Cache -------------------------------------------------------------------
CACHE_STORE=database
# Upgrade path for scale: set CACHE_STORE=redis and QUEUE_CONNECTION=redis once
# a Redis server is available (config/cache.php + config/queue.php already define
# the redis stores). No application code changes are required.

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (real SMTP for production) -----------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
